# SmartEat — variables d'environnement (§4 du cahier des charges).
# Le MVP tourne SANS ces variables (données seedées en mémoire via lib/repo.ts).
# Elles ne deviennent nécessaires qu'au passage en production Supabase/Postgres.

# Supabase (client) — seules les variables NEXT_PUBLIC_* atteignent le navigateur.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase (serveur uniquement — ne JAMAIS exposer au client)
SUPABASE_SERVICE_ROLE_KEY=

# Connexion Postgres poolée (pgbouncer, port 6543) pour les migrations Drizzle
DATABASE_URL=

# Vercel Edge Config (catalogue magasins + feature flags)
EDGE_CONFIG=

# IA — génération de recettes détaillées (Claude). SECRET serveur (pas NEXT_PUBLIC).
# Sans cette clé, l'app affiche les recettes standard du catalogue.
ANTHROPIC_API_KEY=
# Optionnel : modèle (défaut = Claude Haiku, rapide/éco). Ex. claude-sonnet-4-6 pour + de finesse.
ANTHROPIC_MODEL=
